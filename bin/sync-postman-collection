#!/usr/bin/env bash
#
# Downloads the latest Finvalda Postman collection and compares it
# with the local version to find new/removed endpoints.
#
# Usage: bin/sync-postman-collection [--save]
#   --save  Overwrite the local collection with the latest version

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
LOCAL_COLLECTION="$PROJECT_DIR/docs/FvsWebService.postman_collection.json"
API_URL="https://documenter.getpostman.com/api/collections/7208231/2s8YmRMLvd"
TMP_FILE=$(mktemp)

echo "Fetching latest collection from Postman..."
curl -sS "$API_URL" -H "Accept: application/json" -o "$TMP_FILE"

if ! python3 -c "import json; json.load(open('$TMP_FILE'))" 2>/dev/null; then
    echo "Error: Failed to fetch valid JSON from Postman API"
    rm -f "$TMP_FILE"
    exit 1
fi

echo ""
python3 - "$TMP_FILE" "$LOCAL_COLLECTION" <<'PYTHON'
import json, sys

with open(sys.argv[1]) as f:
    latest = json.load(f)
with open(sys.argv[2]) as f:
    local = json.load(f)

def extract_endpoints(items):
    eps = set()
    for item in items:
        if 'item' in item:
            eps.update(extract_endpoints(item['item']))
        elif 'request' in item:
            url = item['request'].get('url', {})
            if isinstance(url, dict):
                path = '/'.join(url.get('path', []))
            else:
                path = url.split('/')[-1].split('?')[0]
            if path:
                eps.add(path)
    return eps

latest_eps = extract_endpoints(latest.get('item', []))
local_eps = extract_endpoints(local.get('item', []))

print(f"Latest (online):  {len(latest_eps)} unique endpoints")
print(f"Local (docs/):    {len(local_eps)} unique endpoints")

new = latest_eps - local_eps
removed = local_eps - latest_eps
common = latest_eps & local_eps

if new:
    print(f"\n🆕 NEW in latest ({len(new)}):")
    for e in sorted(new):
        print(f"  + {e}")

if removed:
    print(f"\n📦 Only in local ({len(removed)}):")
    for e in sorted(removed):
        print(f"  - {e}")

if not new and not removed:
    print("\n✅ Endpoint lists are identical.")
else:
    print(f"\n📊 Common: {len(common)}, New: {len(new)}, Local-only: {len(removed)}")
PYTHON

if [[ "${1:-}" == "--save" ]]; then
    echo ""
    echo "Saving latest collection to $LOCAL_COLLECTION..."
    # Convert v2.0.0 to v2.1.0 format wrapper for consistency
    python3 -c "
import json
with open('$TMP_FILE') as f:
    data = json.load(f)
wrapper = {
    'info': data.get('info', {}),
    'item': data.get('item', []),
    'event': data.get('event', []),
    'variable': data.get('variable', [])
}
with open('$LOCAL_COLLECTION', 'w') as f:
    json.dump(wrapper, f, indent=2, ensure_ascii=False)
print('Saved.')
"
fi

rm -f "$TMP_FILE"
